# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=class_pet_house
DB_USER=root
DB_PASSWORD=your_password

# JWT配置
JWT_SECRET=your-secret-key-change-this
JWT_EXPIRES_IN=7d

# 服务端口
PORT=3000

# 管理后台
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123


LOG_LEVEL=debug|info|warn|error 控制日志量
LOG_IP_DEBUG=1 打开登录 IP 调试日志