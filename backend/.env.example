# 运行环境
NODE_ENV=development

# 数据库配置（当前项目默认使用 SQLite）
DB_STORAGE=class_pets.db

# JWT配置
JWT_SECRET=local-dev-secret
JWT_EXPIRES_IN=7d

# 服务端口
PORT=3001

# 管理后台
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# AI 配置（可选）
AI_API_KEY=
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_MODEL=deepseek-chat

# 短信验证码配置
# 本地开发建议使用 console，验证码会输出在后端日志里
# 正式发送可改为 aliyun_sms 或 aliyun_pnvs，并补齐下面的阿里云参数
SMS_PROVIDER=console
SMS_CODE_EXPIRE_SECONDS=300
SMS_CODE_RESEND_SECONDS=60
SMS_CODE_DAILY_LIMIT=10
SMS_CODE_MAX_FAILURES=5
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SECURITY_TOKEN=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_TEMPLATE_PARAM_CODE_NAME=code
SMS_TEMPLATE_PARAM_EXPIRE_MINUTES_NAME=
SMS_SCHEME_NAME=
SMS_COUNTRY_CODE=86
# 可留空，让不同 provider 自动选默认网关
# aliyun_sms 默认：dysmsapi.aliyuncs.com
# aliyun_pnvs 默认：dypnsapi.aliyuncs.com
SMS_ENDPOINT=
SMS_REGION_ID=cn-hangzhou
SMS_CONNECT_TIMEOUT_MS=5000
SMS_READ_TIMEOUT_MS=10000

# 本地开发默认地址
BACKEND_PUBLIC_URL=http://localhost:3001
PAYMENT_NOTIFY_BASE_URL=http://localhost:3001
PAYMENT_ENABLE_MOCK=true
PAYMENT_ORDER_EXPIRE_MINUTES=15
PAYMENT_LICENSE_PRICE_FEN=1990
PAYMENT_LICENSE_PRODUCT_NAME=石榴果宠物屋系统激活码
PAYMENT_LICENSE_PRODUCT_DESC=支付成功后自动生成 1 个可用激活码

# 支付配置（未接入时可留空）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=
ALIPAY_PUBLIC_KEY_PATH=
ALIPAY_KEY_TYPE=PKCS1
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_ENDPOINT=https://openapi.alipay.com
ALIPAY_PRODUCT_CODE=FACE_TO_FACE_PAYMENT

WECHATPAY_APP_ID=
WECHATPAY_MCH_ID=
WECHATPAY_SERIAL_NO=
WECHATPAY_PRIVATE_KEY_PATH=
WECHATPAY_PLATFORM_PUBLIC_KEY_PATH=
WECHATPAY_PLATFORM_SERIAL=
WECHATPAY_API_V3_KEY=
WECHATPAY_API_BASE=https://api.mch.weixin.qq.com
